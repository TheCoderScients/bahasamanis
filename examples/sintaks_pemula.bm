# Contoh sintaks pemula yang lebih santai

cetak Halo, Indonesia!

fungsi salam
    kembali "Bahasa Manis makin mudah dibaca."
akhir

cetak salam()

nilai = 0

jika benar
    cetak Kondisi benar
akhir

selama nilai < 2
